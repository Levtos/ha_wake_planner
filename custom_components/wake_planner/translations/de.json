{
  "title": "Wake Planner",
  "config": {
    "step": {
      "user": {
        "title": "Wake Planner einrichten",
        "description": "Wähle die Kalender, die Wake Planner lesen soll (beide optional – kannst du auch später in den Einstellungen ergänzen). Personen und Regeln werden nach dem Setup im Wake-Planner-Seitenpanel verwaltet.",
        "data": {
          "calendar_entity_id": "Weck-Kalender (Events wie 'wake: 06:30' überschreiben den Tag)",
          "holiday_calendar_entity_id": "Feiertags-/Urlaubskalender (ganztägige Ereignisse)"
        }
      }
    },
    "abort": {
      "already_configured": "Wake Planner ist bereits konfiguriert."
    }
  },
  "options": {
    "step": {
      "calendar": {
        "title": "Kalender",
        "data": {
          "calendar_entity_id": "Weck-Kalender",
          "holiday_calendar_entity_id": "Feiertags-/Urlaubskalender"
        }
      },
      "special_rules": {
        "title": "Wochenenden & Feiertage",
        "description": "Wie Wochenenden, Feiertage und manuelle Daten den Weckplan beeinflussen. Format: YYYY-MM-DD, MM-DD (jährlich), Bereiche YYYY-MM-DD..YYYY-MM-DD, kommagetrennt.",
        "data": {
          "holiday_behavior": "Verhalten an Wochenenden/Feiertagen",
          "manual_holiday_dates": "Manuelle Daten / Bereiche"
        }
      }
    }
  },
  "entity": {
    "binary_sensor": {
      "wake_needed": { "name": "Wecken nötig" }
    },
    "sensor": {
      "wake_state": {
        "name": "Weckstatus",
        "state": {
          "scheduled": "Geplant",
          "skipped": "Übersprungen",
          "overridden": "Überschrieben",
          "holiday": "Feiertag",
          "inactive": "Inaktiv"
        }
      },
      "next_wake": { "name": "Nächster Wecker" }
    }
  },
  "services": {
    "skip_next": {
      "name": "Nächsten Wecker überspringen",
      "description": "Überspringt den nächsten Wecker einer Person.",
      "fields": {
        "person_id": { "name": "Personen-ID", "description": "Wake-Planner-Personenkennung." }
      }
    },
    "set_override": {
      "name": "Override setzen",
      "description": "Setzt eine manuelle Weckzeit.",
      "fields": {
        "person_id": { "name": "Personen-ID" },
        "wake_time": { "name": "Weckzeit" },
        "until": { "name": "Bis Datum" }
      }
    },
    "clear_override": {
      "name": "Override löschen",
      "description": "Löscht manuelle Override- und Skip-Zustände.",
      "fields": { "person_id": { "name": "Personen-ID" } }
    },
    "add_person": {
      "name": "Person hinzufügen",
      "description": "Legt eine neue Wake-Planner-Person mit Standard-Regel Mo–Fr 07:00 an.",
      "fields": {
        "name": { "name": "Name" },
        "person_entity_id": { "name": "HA-Person-Entity (optional)" },
        "entry_id": { "name": "Config-Entry-ID (nur bei mehreren Wake-Planner-Einträgen nötig)" }
      }
    },
    "remove_person": {
      "name": "Person entfernen",
      "description": "Löscht eine Wake-Planner-Person inklusive aller Regeln.",
      "fields": { "person_id": { "name": "Personen-ID" } }
    },
    "set_rules": {
      "name": "Regeln setzen",
      "description": "Ersetzt die komplette Regelliste einer Person.",
      "fields": {
        "person_id": { "name": "Personen-ID" },
        "rules": { "name": "Regelliste" }
      }
    },
    "set_special_rules": {
      "name": "Sonderregeln setzen",
      "description": "Aktualisiert Feiertagsverhalten und manuelle Feiertagsdaten.",
      "fields": {
        "holiday_behavior": { "name": "Feiertagsverhalten" },
        "manual_holiday_dates": { "name": "Manuelle Feiertagsdaten" }
      }
    }
  },
  "selector": {
    "holiday_behavior": {
      "options": {
        "skip": "Wecker aussetzen",
        "weekend_profile": "Wochenend-Regel (Samstag) verwenden"
      }
    }
  }
}
